{
  "name": "my_timer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron": "vite build && electron .",
    "dist": "npm run dist:electron",
    "dist:electron": "vite build && electron-builder --linux",
    "dist:gtk": "vite build && bash scripts/build-gtk-appimage.sh",
    "gtk": "GDK_BACKEND=x11 python3 gtk_app/timer.py",
    "gtk:dev": "vite build && GDK_BACKEND=x11 python3 gtk_app/timer.py"
  },
  "description": "Interval Timer Application",
  "author": "Nofal",
  "build": {
    "appId": "com.nofal.interval-timer",
    "productName": "Interval Timer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "executableName": "interval-timer",
      "executableArgs": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-dev-shm-usage"
      ]
    }
  },
  "devDependencies": {
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
